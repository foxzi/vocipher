# Vocala configuration
# Copy to config.yaml and adjust values as needed.
# Environment variables override these settings.

server:
  addr: ":8090"             # HTTP listen address
  read_timeout: 15          # seconds
  write_timeout: 30         # seconds
  idle_timeout: 120         # seconds
  log_level: "info"         # debug, info, warn, error

database:
  path: "vocala.db"         # SQLite database file path

webrtc:
  nat_ip: ""                # Host IP for ICE candidates (required in Docker)
  udp_port_min: 40000       # Ephemeral UDP port range start
  udp_port_max: 40200       # Ephemeral UDP port range end
  max_message_kb: 512       # Max WebSocket message size in KB

turn:
  enabled: false            # Enable built-in TURN server
  ip: ""                    # Public IP for TURN (required if enabled)
  port: 3478                # TURN UDP port
  tls_port: 5349            # TURNS TLS port (0 = disabled)
  cert_file: ""             # TLS certificate (e.g. /etc/letsencrypt/live/example.com/fullchain.pem)
  key_file: ""              # TLS private key (e.g. /etc/letsencrypt/live/example.com/privkey.pem)

auth:
  session_days: 30          # Session expiry in days
  min_password: 8           # Minimum password length
  cookie_secure: false      # Set to true when using HTTPS
  registration_enabled: true  # Set false to disable public registration
  rate_limit_rps: 10        # Requests per second per IP
  rate_limit_burst: 20      # Burst limit

# OAuth2 / OpenID Connect (optional)
# Supports Google, GitHub, Keycloak, any OIDC-compatible provider.
# Users who sign in via OAuth are auto-created on first login.
oauth:
  enabled: false
  providers:
    # Google example:
    # - name: Google
    #   client_id: "your-client-id.apps.googleusercontent.com"
    #   client_secret: "your-client-secret"
    #   auth_url: "https://accounts.google.com/o/oauth2/auth"
    #   token_url: "https://oauth2.googleapis.com/token"
    #   userinfo_url: "https://www.googleapis.com/oauth2/v3/userinfo"
    #   scopes: ["openid", "email", "profile"]
    #   auto_activate: true
    #
    # GitHub example:
    # - name: GitHub
    #   client_id: "your-client-id"
    #   client_secret: "your-client-secret"
    #   auth_url: "https://github.com/login/oauth/authorize"
    #   token_url: "https://github.com/login/oauth/access_token"
    #   userinfo_url: "https://api.github.com/user"
    #   scopes: ["user:email"]
    #   auto_activate: true

security:
  allowed_origins: []       # Empty = same-origin only. Add domains for CORS.
